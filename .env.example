# ─── Groq API ─────────────────────────────────────────────────────────────────
# Get your FREE key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── AI Settings ──────────────────────────────────────────────────────────────
AI_MODEL=llama-3.3-70b-versatile
MAX_TOKENS=1024

# ─── Conversation Memory ───────────────────────────────────────────────────────
MAX_HISTORY=10
SESSION_TIMEOUT_MINUTES=30

# ─── Bot Persona ───────────────────────────────────────────────────────────────
BOT_NAME=Aria
BOT_ROLE=a helpful AI assistant
BOT_LANGUAGE=English
